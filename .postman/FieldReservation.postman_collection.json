            }
          }
        },
        {
          "name": "Get Reservation By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/Reservations/0e5b7c8f-1d4a-4a2c-b51c-7a918e612f03",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "Reservations", "0e5b7c8f-1d4a-4a2c-b51c-7a918e612f03"]
            }
          }
        }
      ]
    }
  ]
}