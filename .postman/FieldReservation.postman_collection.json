{
  "info": {
    "name": "FieldReservation API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "your_jwt_token_here",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/Auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "Auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"phoneNumber\": \"+1234567890\",\n  \"password\": \"Password123!\",\n  \"confirmPassword\": \"Password123!\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/Auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "Auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"Password123!\"\n}"
            }
          }
        },
        {
          "name": "Send Email Verification Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/Auth/send-email-verification-token",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "Auth", "send-email-verification-token"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\"\n}"
            }
          }
        },
        {
          "name": "Email Verification",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/Auth/email-verification",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "Auth", "email-verification"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"token\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/Auth/forgot-password",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "Auth", "forgot-password"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\"\n}"
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/Auth/reset-password",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "Auth", "reset-password"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"token\": \"reset-token-received-via-email\",\n  \"newPassword\": \"NewPassword123!\",\n  \"confirmNewPassword\": \"NewPassword123!\"\n}"
            }
          }
        },
        {
          "name": "Google SignIn",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/Auth/google-signin",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "Auth", "google-signin"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"google-id-token\"\n}"
            }
          }
        },
        {
          "name": "Google SignUp",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/Auth/google-signup",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "Auth", "google-signup"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"google-id-token\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/Auth/refresh-token",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "Auth", "refresh-token"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"refresh-token-value\"\n}"
            }
          }
        },
        {
          "name": "Revoke Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/Auth/revoke-refresh-token",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "Auth", "revoke-refresh-token"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"refresh-token-value\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Reservations",
      "item": [
        {
          "name": "Create Reservation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/Reservations",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "Reservations"]
